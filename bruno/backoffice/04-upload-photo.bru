meta {
  name: Upload Photo
  type: http
  seq: 4
}

post {
  url: http://localhost:8081/photographes/{{photographe_id}}/galeries/{{galerie_priv_id}}/photos
  body: multipart-form
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  photo: @file(test-assets/photo-test.jpg)
}

script:post-response {
  const data = res.getBody();
  bru.setVar("photo_id", data.photo_id);
}
